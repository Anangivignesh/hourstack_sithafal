{
  "name": "hourstack-electron",
  "version": "1.0.0",
  "description": "HOURSTACK Desktop Agent - Employee Activity Tracking",
  "private": true,
  "main": "dist/main/main.js",
  "preload": "dist/preload/preload.js",
  "scripts": {
    "dev": "concurrently \"npm run build:watch\" \"electron .\"",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "electron": "^27.0.0",
    "electron-builder": "^24.0.0",
    "typescript": "^5.0.0",
    "concurrently": "^8.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "node-screenshots": "^0.1.10",
    "robotjs": "^0.6.0"
  },
  "build": {
    "appId": "com.hourstack.agent",
    "productName": "HOURSTACK Agent",
    "files": [
      "dist/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
